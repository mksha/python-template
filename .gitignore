# ── hatch-vcs generated version ──
src/my_package/_version.py

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Virtual environments ──
.venv/
venv/

# ── uv ──
