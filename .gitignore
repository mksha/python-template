.uv/

# ── Testing / Coverage ──
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ── Type checking ──
.mypy_cache/

# ── Ruff ──
.ruff_cache/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Environment variables ──
.env
.env.local
